{
  "name": "qa-copilot",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "next dev -H 0.0.0.0 -p 3000",
    "dev:api": "npm run build:api && concurrently \"tsc -w -p backend/tsconfig.json\" \"node --watch backend/dist/server.js\"",
    "build": "npm run build:web && npm run build:api",
    "build:web": "next build",
    "build:api": "tsc -p backend/tsconfig.json",
    "start": "concurrently \"npm run start:web\" \"npm run start:api\"",
    "start:web": "next start -H 0.0.0.0 -p 3000",
    "start:api": "node backend/dist/server.js",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "postinstall": "prisma generate && npx playwright install chromium"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "QA Copilot SaaS web application",
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "next": "^15.5.12",
    "openai": "^6.29.0",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "playwright-chromium": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "stripe": "^20.4.1",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.8",
    "prisma": "^6.16.2",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
